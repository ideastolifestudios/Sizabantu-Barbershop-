rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.email == 'cbrprints22@gmail.com' ||
        (request.auth.token.email != null && 
         request.auth.token.email.matches('.*@sizabantubarbershop\.co\.za'))
      );
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['stamps', 'totalStamps', 'totalVisits', 'rewardsUnlocked', 
                     'role', 'lastRewardedBookingId']);
      // Admins can update everything via Admin SDK (bypasses rules)
    }

    // ── Bookings ────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Users can read their own bookings
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      // ALL writes go through Admin SDK (Vercel API routes) — never from client
      allow write: if false;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Clients can mark notifications as read
      allow update: if isAuth() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // Admin SDK only
    }

    // ── Queue counter (public read for display, no client write) ────────────
    match /counters/{counterId} {
      allow read: if true; // Public queue count for display
      allow write: if false;
    }

    // ── Services (public read) ──────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Barbers (public read) ───────────────────────────────────────────────
    match /barbers/{barberId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Rate limiting ────────────────────────────────────────────────────────
    match /ratelimit/{key} {
      allow read: if false;
      allow write: if false; // Admin SDK only
    }

    // ── Deny all other ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
