{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/scheduler/reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/scheduler/expire",
      "schedule": "*/10 * * * *"
    }
  ]
}
